        "jsonBody": "={{ {\n  status: 'uploaded',\n  storage_path: $node['HTTP Request FastAPI /jobs/clip'].json.storage_path,\n  tiktok_post_id: $json.data?.publish_id || $json.publish_id || null,\n  updated_at: new Date().toISOString()\n} }}"
      },
