      "id": "webhook_trigger",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [220, 320]
    },
    {
      "parameters": {
        "jsCode": "const body = $json.body || {};\nif (!body.youtube_url || !body.keyword) {\n  throw new Error('youtube_url and keyword are required');\n}\nconst duration_target = body.duration_target ?? 20;\nconst caption = body.caption ?? '';\nreturn [{ json: {\n  youtube_url: body.youtube_url,\n  keyword: body.keyword,\n  duration_target,\n  caption,\n  requested_at: new Date().toISOString()\n}}];"
      },
      "id": "validate_input",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [470, 320]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.SUPABASE_URL + '/rest/v1/clip_jobs'}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$env.SUPABASE_SERVICE_ROLE_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.SUPABASE_SERVICE_ROLE_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ [{\n  youtube_url: $json.youtube_url,\n  keyword: $json.keyword,\n  status: 'queued'\n}] }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "insert_job_supabase",
      "name": "Insert Job to Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [730, 320]
    },
    {
      "parameters": {
        "jsCode": "const createdRows = $input.first().json;\nconst row = Array.isArray(createdRows) ? createdRows[0] : createdRows;\nif (!row || !row.id) {\n  throw new Error('Failed to create clip job in Supabase');\n}\nreturn [{ json: {\n  job_id: row.id,\n  youtube_url: row.youtube_url,\n  keyword: row.keyword,\n  duration_target: $node['Validate Input'].json.duration_target,\n  caption: $node['Validate Input'].json.caption\n}}];"
      },
      "id": "prepare_fastapi_payload",
      "name": "Prepare FastAPI Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [990, 320]
    },
