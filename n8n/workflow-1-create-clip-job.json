      "parameters": {
        "method": "POST",
        "url": "={{$env.FASTAPI_BASE_URL + '/jobs/clip'}}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  job_id: $json.job_id,\n  youtube_url: $json.youtube_url,\n  keyword: $json.keyword,\n  duration_target: $json.duration_target\n} }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "call_fastapi_jobs_clip",
      "name": "HTTP Request FastAPI /jobs/clip",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1260, 320]
