{
  "info": {
    "_postman_id": "d3f54aa1-8d2e-4f90-b53b-c5d90ae67bf1",
    "name": "Autoclipper Two Mode API",
    "description": "Collection untuk testing backend Autoclipper two-mode flow: Discover Mode dan Auto Detect from YouTube.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Discover Jobs",
      "item": [
        {
          "name": "Create Discover Job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"topic\": \"social media marketing\",\n  \"niche\": \"business\",\n  \"goal\": \"find good videos to turn into clips\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/discover-jobs",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "discover-jobs"]
            }
          }
        },
        {
          "name": "List Discover Jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/discover-jobs?limit=20&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "discover-jobs"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Clip Jobs",
      "item": [
        {
          "name": "Analyze Auto Detect",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.job_id) pm.collectionVariables.set('job_id', json.job_id);",
                  "  if (json.candidates && json.candidates.length > 0 && json.candidates[0].id) {",
                  "    pm.collectionVariables.set('candidate_id', json.candidates[0].id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mode\": \"auto_detect\",\n  \"youtube_url\": \"https://www.youtube.com/watch?v=dQw4w9WgXcQ\",\n  \"clip_count\": 5,\n  \"duration_target\": 20,\n  \"tone\": \"educational\",\n  \"audience\": \"general\",\n  \"keyword\": \"marketing hook\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/analyze",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", "analyze"]
            }
          }
        },
        {
          "name": "List Clip Jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs?limit=20&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            }
          }
        },
        {
          "name": "Get Job Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/{{job_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", "{{job_id}}"]
            }
          }
        },
        {
          "name": "Render Selected Candidate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"candidate_id\": \"{{candidate_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/{{job_id}}/render",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", "{{job_id}}", "render"]
            }
          }
        },
        {
          "name": "Schedule Upload Metadata",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scheduled_at\": \"2026-03-21T10:00:00+07:00\",\n  \"caption\": \"my TikTok caption\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/{{job_id}}/schedule",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", "{{job_id}}", "schedule"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "job_id",
      "value": ""
    },
    {
      "key": "candidate_id",
      "value": ""
    }
  ]
}
